def create_project_config(path, forced_mode=None, args=None):
    print(f"\n{t('project_wizard.title')}\n")

    default_name = Path(path).name or "project"
    default_remote_path = "/var/www/cms"
    non_interactive = bool(getattr(args, "yes", False)) or not sys.stdin.isatty()

    name = getattr(args, "name", None) or default_name
    remote_host = getattr(args, "host", None)
    remote_path = getattr(args, "remote_path", None)

    if not remote_host and not non_interactive:
        name = input(f"{t('project_wizard.project_name', default=default_name)}").strip() or default_name
        remote_host = input(f"{t('project_wizard.remote_host')}").strip()
        remote_path = input(f"{t('project_wizard.remote_path', default=default_remote_path)}").strip() or default_remote_path

        while not remote_host:
            remote_host = input(f"{t('project_wizard.remote_host_required')}").strip()

        while not remote_path.startswith("/"):
            remote_path = input(f"{t('project_wizard.remote_path_absolute', default=default_remote_path)}").strip() or default_remote_path
    else:
        if not remote_host:
            print("Missing required --host for non-interactive project creation.")
            sys.exit(2)
        remote_path = remote_path or default_remote_path
        if not remote_path.startswith("/"):
            print("--remote-path must be an absolute path starting with /.")
            sys.exit(2)

    if getattr(args, "pull_interval", None) is not None:
        pull_interval = args.pull_interval
    elif non_interactive:
        pull_interval = 60
    else:
        pull_interval = prompt_int(t('project_wizard.pull_interval'), 60)

    if getattr(args, "debounce", None) is not None:
        debounce = args.debounce
    elif non_interactive:
        debounce = 0.3
    else:
        debounce = prompt_float(t('project_wizard.debounce'), 0.3)

    if getattr(args, "delete_remote", None) is not None:
        delete_remote = args.delete_remote
    elif non_interactive:
        delete_remote = False
    else:
        delete_remote = prompt_bool(t('project_wizard.delete_remote'), False)

    mode = forced_mode or "unison"
    pid_file = str(RUN_DIR / f"{project_id(path)}.pid")
    log_file = str(LOG_DIR / f"{name}.log")
    worktree_path = ensure_worktree_dir(path)

    return {
        "id": project_id(path),
        "name": name,
        "path": path,
        "worktree_path": worktree_path,
        "remote_host": remote_host,
        "remote_path": remote_path,
        "mode": mode,
        "pull_interval": pull_interval,
        "debounce": debounce,
        "delete_remote": delete_remote,
        "active": False,
        "pid": None,
        "pid_file": pid_file,
        "log_file": log_file,
        "created_at": now(),
        "updated_at": now(),
        "started_at": None,
        "stopped_at": None,
        "last_unison_at": None,
        "last_rsync_pull_at": None,
        "last_rsync_push_at": None,
        "last_commit_at": None,
        "last_error": None,
    }


def unison_remote(project):
    return f"ssh://{project['remote_host']}/{project['remote_path']}"


def run_unison(project, batch=False):
    cmd = [
        "unison",
        project_worktree(project),
        unison_remote(project),
        "-ignore", "Name .git",
        "-ignore", "Name .DS_Store",
        "-ignore", "Name .usp-cache",
        "-terse",
    ]
    if batch:
        cmd += ["-batch", "-auto"]
    return run(cmd)


def rsync_pull(project):
    source = f"{project['remote_host']}:{project['remote_path'].rstrip('/')}/"
    dest = project_worktree(project).rstrip("/") + "/"
    cmd = [
        "rsync", "-az",
        "--omit-dir-times",
        "--exclude", ".git",
        "--exclude", ".DS_Store",
        "--exclude", ".usp-cache",
        source, dest,
    ]
    return run(cmd)


def rsync_push(project):
    source = project_worktree(project).rstrip("/") + "/"
    dest = f"{project['remote_host']}:{project['remote_path'].rstrip('/')}/"
    cmd = [
        "rsync", "-az",
        "--omit-dir-times",
        "--exclude", ".git",
        "--exclude", ".DS_Store",
        "--exclude", ".usp-cache",
    ]
    if project.get("delete_remote"):
        cmd.append("--delete")
    cmd += [source, dest]
    return run(cmd)


def initial_sync_with_fallback(project):
    mode = project.get("mode", "unison")

    if mode == "rsync":
        print(f"\n[{PROGRAM_NAME}] Startowy sync: rsync pull")
        result = rsync_pull(project)
        return result.returncode, "rsync"

    if not shutil.which("unison"):
        print(f"\n[{PROGRAM_NAME}] Unison nie jest lokalnie dostępny → fallback do rsync pull")
        result = rsync_pull(project)
        return result.returncode, "rsync"

    print(f"\n[{PROGRAM_NAME}] Startowy sync: Unison")
    result = run_unison(project, batch=False)
    if result.returncode == 0:
        return 0, "unison"

    print(f"\n[{PROGRAM_NAME}] Unison failed → fallback do rsync pull\n")
    result = rsync_pull(project)
    return result.returncode, "rsync"


def pid_alive(pid):
    if not pid:
        return False
    try:
        os.kill(int(pid), 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except Exception:
        return False


def reconcile_state(state):
    changed = False
    for project in state.get("projects", {}).values():
        if project.get("active") and not pid_alive(project.get("pid")):
            project["active"] = False
            project["pid"] = None
            project["stopped_at"] = now()
            project["last_error"] = f"PID not alive during {PROGRAM_NAME} state reconciliation"
            changed = True
    if changed:
        save_state(state)
    return state


def print_active_tunnels(state):
    active = [
        p for p in state.get("projects", {}).values()
        if p.get("active") and pid_alive(p.get("pid"))
    ]

    print(f"Aktywne tunele: {len(active)}")
    for p in active:
        print(f"  - {p['name']} | mode={p.get('mode', 'unison')} | PID {p.get('pid')} | {p['path']}")


def resolve_project_key(state, path=None, name=None, default_to_cwd=True):
    projects = state.get("projects", {})

    if path:
        key = abs_path(path)
        return key if key in projects else None

    if name:
        matches = [key for key, project in projects.items() if project.get("name") == name]
        if not matches:
            return None
        if len(matches) > 1:
            print(f"Znaleziono wiele projektów o nazwie '{name}':")
            for key in matches:
                project = projects[key]
                print(f"- path={project['path']} | worktree={project_worktree(project)}")
            print("Użyj --path, żeby wskazać konkretny projekt.")
            sys.exit(2)
        return matches[0]

    if default_to_cwd:
        return current_project_key(state=state)

    return None


def daemon_env():
    env = os.environ.copy()
    env["JKS_CONTROL_NAME"] = PROGRAM_NAME
    env["JKS_CONFIG_NAME"] = CONFIG_NAME
    return env


def start_background_daemon(project, path, uspd):
    log_file = Path(project["log_file"])
    log_file.parent.mkdir(parents=True, exist_ok=True)
    cmd = [sys.executable, uspd, "--project", path]

    with log_file.open("a", encoding="utf-8") as log:
        process = subprocess.Popen(cmd, stdout=log, stderr=log, start_new_session=True, env=daemon_env())

    project["active"] = True
    project["pid"] = process.pid
    project["started_at"] = now()
    project["updated_at"] = now()
    project["last_error"] = None
    Path(project["pid_file"]).write_text(str(process.pid), encoding="utf-8")

    return process


def validate_open_args(args):
    if getattr(args, "live", False) and getattr(args, "background", False):
        fail("Choose either --live or --background, not both.", EXIT_USAGE)
    if getattr(args, "pull_interval", None) is not None and args.pull_interval < 1:
        fail("--pull-interval must be >= 1.", EXIT_USAGE)
    if getattr(args, "debounce", None) is not None and args.debounce < 0:
        fail("--debounce must be >= 0.", EXIT_USAGE)
    if getattr(args, "remote_path", None) and not args.remote_path.startswith("/"):
        fail("--remote-path must be an absolute path starting with /.", EXIT_USAGE)


def project_summary(project):
    active = project.get("active") and pid_alive(project.get("pid"))
    payload = dict(project)
    payload["active"] = bool(active)
    payload["pid_alive"] = bool(active)
    payload["worktree_path"] = project_worktree(project)
    return payload


def planned_project_from_args(path, args):
    default_name = Path(path).name or "project"
    return {
        "id": project_id(path),
        "name": getattr(args, "name", None) or default_name,
        "path": path,
        "worktree_path": worktree_path_for(path),
        "remote_host": getattr(args, "host", None),
        "remote_path": getattr(args, "remote_path", None) or "/var/www/cms",
        "mode": getattr(args, "mode", None) or "unison",
        "pull_interval": getattr(args, "pull_interval", None) or 60,
        "debounce": getattr(args, "debounce", None) if getattr(args, "debounce", None) is not None else 0.3,
        "delete_remote": bool(getattr(args, "delete_remote", False)),
        "config": str(STATE_FILE),
        "logs": str(LOG_DIR),
        "run": str(RUN_DIR),
    }


def dry_run_open(args):
    validate_open_args(args)
    state = reconcile_state(load_state())
    path = current_project_key(state=state)
    existing = state.get("projects", {}).get(path)
    plan = {
        "program": PROGRAM_NAME,
        "version": VERSION,
        "command": args.command,
        "session_root": path,
        "exists": bool(existing),
        "action": "reuse" if existing else "create",
        "project": project_summary(existing) if existing else planned_project_from_args(path, args),
        "will_sync": args.command == "open",
        "will_start_daemon": args.command == "open",
    }
    if getattr(args, "json", False):
        print_json(plan)
    else:
        print(f"{PROGRAM_NAME} dry-run")
        print(f"Session root: {plan['session_root']}")
        print(f"Action: {plan['action']}")
        p = plan["project"]
        print(f"Project: {p.get('name')}")
        print(f"Worktree: {p.get('worktree_path')}")
        print(f"Remote: {p.get('remote_host')}:{p.get('remote_path')}")
        print(f"Mode: {p.get('mode')}")
        print(f"Config: {STATE_FILE}")
        print(f"Will sync: {plan['will_sync']}")
        print(f"Will start daemon: {plan['will_start_daemon']}")


def preflight_layout(path, project, non_interactive=False):
    session_root = Path(path)
    worktree = Path(project_worktree(project))
    allowed = {".git", ".gitignore", WORKTREE_DIRNAME}
    warnings = []
    if worktree.exists() and any(worktree.iterdir()):
        warnings.append(f"Worktree is not empty before initial sync: {worktree}")
    root_payload = [p.name for p in session_root.iterdir() if p.name not in allowed and not p.name.startswith(".jks")]
    if root_payload:
        warnings.append("Session root contains files outside worktree/: " + ", ".join(sorted(root_payload)[:20]))
    for warning in warnings:
        print(f"⚠ {warning}")
    return warnings


def start_live_daemon(project, path, uspd):
    log_file = Path(project["log_file"])
    log_file.parent.mkdir(parents=True, exist_ok=True)
    cmd = [sys.executable, uspd, "--project", path]

    process = subprocess.Popen(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
        env=daemon_env(),
    )

    project["active"] = True
    project["pid"] = process.pid
    project["started_at"] = now()
    project["updated_at"] = now()
    project["last_error"] = None
    Path(project["pid_file"]).write_text(str(process.pid), encoding="utf-8")

    print(f"\nTryb live. Ctrl+C zatrzyma {daemon_name()} graceful shutdownem.\n")

    with log_file.open("a", encoding="utf-8") as log:
        try:
            if process.stdout:
                for line in process.stdout:
                    print(line, end="")
                    log.write(line)
                    log.flush()
            return process.wait()
        except KeyboardInterrupt:
            print(f"\n{t('live.interrupt', daemon=daemon_name())}\n")
            try:
                process.send_signal(2)
            except Exception:
                pass
            return process.wait()


def open_project(args):
    validate_open_args(args)
    if getattr(args, "dry_run", False):
        dry_run_open(args)
        return
    doctor(exit_on_missing=True)

    lock_context = state_lock()
    lock_context.__enter__()
    atexit.register(lambda: lock_context.__exit__(None, None, None))
    state = reconcile_state(load_state())
    path = current_project_key(state=state)
    Path(path).mkdir(parents=True, exist_ok=True)
    worktree_path = ensure_worktree_dir(path)

    projects = state.setdefault("projects", {})

    print_active_tunnels(state)

    created_git = False
    created_gitignore = False

    try:
        if path not in projects:
            created_git, created_gitignore = ensure_git_with_tracking(path)
            projects[path] = create_project_config(path, forced_mode=args.mode, args=args)
            save_state(state)
        else:
            project = projects[path]
            project["worktree_path"] = project.get("worktree_path") or worktree_path
            ensure_git(path)

            action = "continue"
            if not args.yes:
                action = prompt_existing_project_action(project)

            if action == "cancel":
                print(t('cancelled'))
                return

            if action == "disable":
                close_args = argparse.Namespace(wait=True, timeout=30, path=path, name=None)
                close_project(close_args)
                return

            if action in ["continue", "enable"] and project.get("active") and pid_alive(project.get("pid")):
                print(f"\n{t('project.already_active_pid', pid=project['pid'])}")
                return

            if action == "reconfigure":
                new_project = create_project_config(path, forced_mode=args.mode, args=args)
                new_project["created_at"] = project.get("created_at", new_project["created_at"])
                projects[path] = new_project
            else:
                if args.mode:
                    project["mode"] = args.mode
                project["updated_at"] = now()
            save_state(state)
    except KeyboardInterrupt:
        cleanup_aborted_init(path, created_git=created_git, created_gitignore=created_gitignore)
        sys.exit(130)

    project = projects[path]

    if project.get("active") and pid_alive(project.get("pid")):
        print(f"\n{t('project.already_active_pid', pid=project['pid'])}")
        if prompt_bool(t('project.close_it'), False):
            close_project(args)
        return

    if args.command == "init":
        save_state(state)
        print(f"Initialized {PROGRAM_NAME} project without starting {daemon_name()}.")
        print(f"Project: {project['name']}")
        print(f"Worktree: {project_worktree(project)}")
        return

    preflight_layout(path, project, non_interactive=getattr(args, "yes", False))

    print(f"\n{t('sync.initial_start')}")
    print(f"{t('sync.initial_hint')}\n")

    try:
        code, used_mode = initial_sync_with_fallback(project)
    except KeyboardInterrupt:
        print(f"\n{t('sync.initial_interrupted')}")
        sys.exit(130)

    project["mode"] = used_mode
    project["updated_at"] = now()

    if code != 0:
        project["last_error"] = f"initial {used_mode} sync failed with code {code}"
        save_state(state)
        print(f"\n{t('sync.initial_failed', mode=used_mode, daemon=daemon_name())}")
        sys.exit(code)

    if used_mode == "unison":
        project["last_unison_at"] = now()
    else:
        project["last_rsync_pull_at"] = now()

    if git_commit(path, f"{PROGRAM_NAME} open {now()}"):
        project["last_commit_at"] = now()

    save_state(state)

    try:
        if getattr(args, "live", False):
            run_mode = "live"
        elif getattr(args, "background", False) or args.yes:
            run_mode = "background"
        else:
            run_mode = prompt_run_mode(default="background")
    except KeyboardInterrupt:
        print(f"\n{t('daemon.start_interrupted')}")
        sys.exit(130)

    daemon_path = find_daemon()

    if run_mode == "background":
        process = start_background_daemon(project, path, daemon_path)
        save_state(state)

        print(f"\n{t('daemon.started_background')}")
        print(f"{t('label.project')} {project['name']}")
        print(f"{t('label.mode')} {project.get('mode', 'unison')}")
        print(f"{t('label.worktree')} {project_worktree(project)}")
        print(f"PID:     {process.pid}")
        print(f"Log:     {project['log_file']}")
        return

    save_state(state)
    exit_code = start_live_daemon(project, path, daemon_path)
    state = reconcile_state(load_state())
    save_state(state)
    if exit_code not in [0, None]:
        sys.exit(exit_code)


def close_project(args):
    state = reconcile_state(load_state())
    path = resolve_project_key(
        state,
        path=getattr(args, "path", None),
        name=getattr(args, "name", None),
    )
    project = state.get("projects", {}).get(path)

    if not project:
        if getattr(args, "path", None):
            print(f"Projekt o path {abs_path(args.path)} nie jest zarejestrowany.")
        elif getattr(args, "name", None):
            print(f"Projekt o nazwie {args.name} nie jest zarejestrowany.")
        else:
            print(t('project.not_registered_here'))
        return

    pid = project.get("pid")
    if not project.get("active") or not pid_alive(pid):
        if getattr(args, "path", None) or getattr(args, "name", None):
            print(f"Projekt {project['name']} nie jest aktywny.")
        else:
            print(t('project.not_active_here'))
        project["active"] = False
        project["pid"] = None
        save_state(state)
        return

    print(t('daemon.closing_project', daemon=daemon_name(), project=project['name'], pid=pid))
    os.kill(int(pid), 15)

    wait = getattr(args, "wait", True)
    timeout = getattr(args, "timeout", 30)

    if wait:
        for _ in range(timeout):
            time.sleep(1)
            state = reconcile_state(load_state())
            project = state.get("projects", {}).get(path)
            if not project or not project.get("active"):
                print(t('daemon.closed'))
                return

        print(t('daemon.still_running_check_log'))
        print(project.get("log_file"))


def remove_project(args):
    state = reconcile_state(load_state())
    projects = state.setdefault("projects", {})
    path = resolve_project_key(state, path=getattr(args, "path", None), name=getattr(args, "name", None))
    project = projects.get(path)

    if not project:
        if getattr(args, "path", None):
            print(f"Projekt o path {abs_path(args.path)} nie jest zarejestrowany.")
        elif getattr(args, "name", None):
            print(f"Projekt o nazwie {args.name} nie jest zarejestrowany.")
        else:
            print("Ten katalog nie jest zarejestrowany.")
        return

    session_root = Path(path)
    worktree = Path(project_worktree(project))
    hard_remove = getattr(args, "hard", False)

    pid = project.get("pid")
    if project.get("active") and pid_alive(pid):
        if getattr(args, "force", False) or prompt_bool(f"Projekt {project['name']} ma aktywny tunel PID {pid}. Zamknąć?", True):
            close_args = argparse.Namespace(wait=True, timeout=getattr(args, "timeout", 30), path=path, name=None)
            close_project(close_args)
            state = reconcile_state(load_state())
            projects = state.setdefault("projects", {})
            project = projects.get(path)
        else:
            print("Nie usuwam aktywnego projektu.")
            return

    if hard_remove:
        resolved_root = session_root.resolve()
        if resolved_root in [Path("/"), Path.home().resolve()] or len(resolved_root.parts) < 4:
            print("Odmowa hard remove dla niebezpiecznej ścieżki session root.")
            return
        if not (session_root / ".git").exists() or Path(project_worktree(project)).resolve().parent != resolved_root:
            print("Odmowa hard remove: katalog nie wygląda jak session root JKSync z lokalnym worktree/.")
            return
        if not sys.stdin.isatty() and not getattr(args, "yes", False):
            print("Odmowa hard remove bez --yes w trybie non-interactive.")
            return
        if not getattr(args, "yes", False):
            if not prompt_bool(f"Twardo usunąć projekt {project['name']} razem z katalogiem {session_root}?", False):
                print("Anulowano.")
                return
    else:
        if not getattr(args, "yes", False):
            if not prompt_bool(f"Usunąć projekt {project['name']} z rejestru?", False):
                print("Anulowano.")
                return

    pid_file = project.get("pid_file")
    if pid_file:
        try:
            Path(pid_file).unlink(missing_ok=True)
            print(f"Usunięto PID file: {pid_file}")
        except Exception as exc:
            print(f"Nie udało się usunąć PID file: {exc}")

    log_file = project.get("log_file")
    if log_file and (getattr(args, "remove_log", False) or hard_remove):
        try:
            Path(log_file).unlink(missing_ok=True)
            print(f"Usunięto log: {log_file}")
        except Exception as exc:
            print(f"Nie udało się usunąć logu: {exc}")

    if getattr(args, "remove_git", False) and not hard_remove:
        git_dir = session_root / ".git"
        gitignore = session_root / ".gitignore"

        if git_dir.exists():
            if getattr(args, "yes", False) or prompt_bool("Usunąć lokalne .git?", False):
                shutil.rmtree(git_dir)
                print("Usunięto .git")

        if gitignore.exists():
            if getattr(args, "yes", False) or prompt_bool("Usunąć lokalne .gitignore?", False):
                gitignore.unlink()
                print("Usunięto .gitignore")

    projects.pop(path, None)
    save_state(state)

    if hard_remove:
        if worktree.exists() and worktree.parent != session_root:
            try:
                shutil.rmtree(worktree)
                print(f"Usunięto worktree: {worktree}")
            except Exception as exc:
                print(f"Nie udało się usunąć worktree: {exc}")

        try:
            shutil.rmtree(session_root)
            print(f"Usunięto katalog projektu: {session_root}")
        except Exception as exc:
            print(f"Projekt usunięto z rejestru, ale nie udało się usunąć katalogu: {exc}")
            return

        print(f"Twardo usunięto projekt: {path}")
        return

    print(f"Usunięto projekt z rejestru: {path}")

