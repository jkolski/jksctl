    p.add_argument("-y", "--yes", action="store_true", help="Nie pytaj o potwierdzenie usunięcia z rejestru")
    p.add_argument("-f", "--force", action="store_true", help="Zamknij aktywny daemon bez pytania")
    p.add_argument("--path", help="Usuń projekt wskazany absolutną lub względną ścieżką session root")
    p.add_argument("--name", help="Usuń projekt po nazwie; jeśli nazwa nie jest unikalna, użyj --path")
    p.add_argument("--timeout", type=int, default=30, help="Ile sekund czekać na zamknięcie daemona")
    p.add_argument("--hard", action="store_true", help="Twardo usuń projekt: wykreśl z rejestru i skasuj katalog projektu")
    p.add_argument("--remove-git", action="store_true", help="Opcjonalnie usuń .git i .gitignore z session root")
    p.add_argument("--remove-log", action="store_true", help="Opcjonalnie usuń log projektu")
    return p

def add_logs_parser(sub, name):
    p = sub.add_parser(name)
    p.add_argument("-n", "--lines", type=int, default=80)
    return p


def add_config_parser(sub, name):
    p = sub.add_parser(name)
    p.add_argument("--language", choices=sorted(SUPPORTED_LANGUAGES.keys()), help="Set UI language")
    return p


def add_json_parser(sub, name):
    p = sub.add_parser(name)
    p.add_argument("--json", action="store_true", help="Emit machine-readable JSON")
    return p


def add_doctor_parser(sub, name):
    p = sub.add_parser(name)
    p.add_argument("--json", action="store_true", help="Emit machine-readable JSON")
    p.add_argument("--host", help="SSH host to check")
    p.add_argument("--remote-path", help="Remote path to check on --host")
    return p


def main():
    load_translations()
    parser = argparse.ArgumentParser(prog=PROGRAM_NAME)
    sub = parser.add_subparsers(dest="command")

    add_open_parser(sub, "open")
    add_open_parser(sub, "init")
    add_close_parser(sub, "close")
    add_json_parser(sub, "status")
    add_json_parser(sub, "list")
    add_doctor_parser(sub, "doctor")
    add_json_parser(sub, "version")
    add_config_parser(sub, "config")
    add_logs_parser(sub, "logs")
    add_remove_parser(sub, "remove")

    for alias in ["start", "go", "up"]:
        add_open_parser(sub, alias)
    for alias in ["stop", "halt", "down", "end"]:
        add_close_parser(sub, alias)
    for alias in ["state", "info"]:
        add_json_parser(sub, alias)
    for alias in ["ls", "projects", "tunnels"]:
        add_json_parser(sub, alias)
    for alias in ["check", "diagnose"]:
        add_doctor_parser(sub, alias)
    for alias in ["paths"]:
        add_config_parser(sub, alias)
    for alias in ["log", "tail"]:
        add_logs_parser(sub, alias)

    for alias in ["rm", "delete", "unregister"]:
        add_remove_parser(sub, alias)

    args = parser.parse_args()

    if not args.command:
        args.command = "open"
        args.yes = False
        args.mode = None
        args.live = False
        args.background = False
        args.dry_run = False
        args.json = False

    args.command = ALIASES.get(args.command, args.command)
    ensure_language_initialized(args)

    if args.command in ["open", "init"]:
        open_project(args)
    elif args.command == "close":
        close_project(args)
    elif args.command == "status":
        status_project(args)
    elif args.command == "list":
        list_projects(args)
    elif args.command == "doctor":
        doctor(exit_on_missing=False, args=args)
    elif args.command == "config":
        with state_lock():
            config(args)
    elif args.command == "logs":
        logs(args)
    elif args.command == "remove":
        with state_lock():
            remove_project(args)
    elif args.command == "version":
        version(args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nCancelled.")
        sys.exit(130)
