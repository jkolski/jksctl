def now():
    return datetime.now().isoformat(timespec="seconds")


def print_json(payload):
    print(json.dumps(payload, indent=2, ensure_ascii=False))


def fail(message, code=EXIT_USAGE):
    print(message, file=sys.stderr)
    sys.exit(code)


@contextlib.contextmanager
def state_lock():
    ensure_dirs()
    with LOCK_FILE.open("w", encoding="utf-8") as lock:
        try:
            fcntl.flock(lock.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            fail(f"Another {PROGRAM_NAME} process is already changing state: {LOCK_FILE}", EXIT_DAEMON_CONFLICT)
        try:
            yield
        finally:
            fcntl.flock(lock.fileno(), fcntl.LOCK_UN)


def _po_unquote(value):
    return json.loads(value)


def load_po(path):
    catalog = {}
    if not path.exists():
        return catalog

    current_key = None
    current_value = None
    active = None

    def flush():
        if current_key is not None and current_value is not None:
            catalog[current_key] = current_value

    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("msgid "):
            flush()
            current_key = _po_unquote(line[6:].strip())
            current_value = None
            active = "msgid"
        elif line.startswith("msgstr "):
            current_value = _po_unquote(line[7:].strip())
            active = "msgstr"
        elif line.startswith('"') and active == "msgid":
            current_key = (current_key or "") + _po_unquote(line)
        elif line.startswith('"') and active == "msgstr":
            current_value = (current_value or "") + _po_unquote(line)

    flush()
    catalog.pop("", None)  # header
    return catalog


def load_translations():
    global TRANSLATIONS
    TRANSLATIONS = {}
    for lang in SUPPORTED_LANGUAGES:
        TRANSLATIONS[lang] = load_po(LOCALE_DIR / f"{lang}.po")


def set_language(lang):
    global CURRENT_LANGUAGE
    CURRENT_LANGUAGE = lang if lang in SUPPORTED_LANGUAGES else "en"


def t(key, **kwargs):
    text = (
        TRANSLATIONS.get(CURRENT_LANGUAGE, {}).get(key)
        or TRANSLATIONS.get("en", {}).get(key)
        or key
    )
    return text.format(**kwargs)


def migrate_legacy_config_if_needed():
    if LEGACY_APP_DIR is None or APP_DIR.exists() or not LEGACY_APP_DIR.exists():
        return

    APP_DIR.parent.mkdir(parents=True, exist_ok=True)
    LEGACY_APP_DIR.rename(APP_DIR)

    if STATE_FILE.exists():
        state = json.loads(STATE_FILE.read_text(encoding="utf-8"))
        changed = False
        for project in state.get("projects", {}).values():
            pid_file = project.get("pid_file")
            log_file = project.get("log_file")
            if pid_file and "/.config/uspctl/" in pid_file:
                project["pid_file"] = pid_file.replace("/.config/uspctl/", f"/.config/{CONFIG_NAME}/")
                changed = True
            if log_file and "/.config/uspctl/" in log_file:
                project["log_file"] = log_file.replace("/.config/uspctl/", f"/.config/{CONFIG_NAME}/")
                changed = True
        if changed:
            STATE_FILE.write_text(json.dumps(state, indent=2, ensure_ascii=False), encoding="utf-8")


def ensure_dirs():
    migrate_legacy_config_if_needed()
    APP_DIR.mkdir(parents=True, exist_ok=True)
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    RUN_DIR.mkdir(parents=True, exist_ok=True)


def empty_state():
    return {"version": 1, "meta": {"language": "en"}, "projects": {}}


def load_state():
    ensure_dirs()
    if not STATE_FILE.exists() or STATE_FILE.stat().st_size == 0:
        return empty_state()
    try:
        with STATE_FILE.open("r", encoding="utf-8") as f:
            return json.load(f)
    except json.JSONDecodeError:
        backup = STATE_FILE.with_suffix(f".broken.{int(time.time())}.json")
        STATE_FILE.rename(backup)
        print(f"Uszkodzony state.json przeniesiony do: {backup}")
        return empty_state()


def save_state(state):
    ensure_dirs()
    tmp = STATE_FILE.with_suffix(".tmp")
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(state, f, indent=2, ensure_ascii=False)
    tmp.replace(STATE_FILE)


def prompt_language(default="en"):
    print("Choose language / Wybierz język:")
    print("  1) English")
    print("  2) Polski")

    options = {"1": "en", "2": "pl", "en": "en", "english": "en", "pl": "pl", "polski": "pl"}
    default_label = "1" if default == "en" else "2"

    while True:
        try:
            value = input(f"Choice / Wybór [{default_label}]: ").strip().lower()
        except KeyboardInterrupt:
            print("\nCancelled.")
            sys.exit(130)
        if not value:
            return default
        if value in options:
            return options[value]
        print("Please choose 1/2 (English/Polski).")


def ensure_language_initialized(args=None):
    state_exists = STATE_FILE.exists()
    if getattr(args, "dry_run", False) and not state_exists:
        set_language("en")
        return empty_state()

    state = load_state()
    meta = state.setdefault("meta", {})
    lang = meta.get("language")

    if not lang or not state_exists:
        if sys.stdin.isatty() and not getattr(args, "yes", False):
            lang = prompt_language(default=lang or "en")
        else:
            lang = lang or "en"
        meta["language"] = lang
        save_state(state)

    set_language(lang)
    return state


def set_language_in_state(lang):
    state = load_state()
    state.setdefault("meta", {})["language"] = lang
    save_state(state)
    set_language(lang)


def abs_path(path):
    return str(Path(path).expanduser().resolve())


def project_id(path):
    return hashlib.sha1(abs_path(path).encode("utf-8")).hexdigest()[:12]


def current_project_key(state=None, cwd=None):
    current = Path(cwd or os.getcwd()).expanduser().resolve()

    if state:
        projects = state.get("projects", {})
        for candidate in [current, *current.parents]:
            key = str(candidate)
            if key in projects:
                return key

    return str(current)


def worktree_path_for(path):
    return str(Path(path) / WORKTREE_DIRNAME)


def project_worktree(project):
    return abs_path(project.get("worktree_path") or worktree_path_for(project["path"]))


def ensure_worktree_dir(path):
    worktree = Path(worktree_path_for(path))
    worktree.mkdir(parents=True, exist_ok=True)
    return str(worktree)


def daemon_name():
    return DEFAULT_DAEMON_NAME


def find_daemon():
    here_dir = Path(__file__).resolve().parent
    candidates = [daemon_name(), "jksd", "uspd"]

    for candidate in candidates:
        here = here_dir / candidate
        if here.exists():
            return str(here)

    for candidate in candidates:
        found = shutil.which(candidate)
        if found:
            return found

    print(f"Nie znaleziono `{daemon_name()}` obok `{PROGRAM_NAME}` ani w PATH.")
    print("Umieść oba pliki w tym samym katalogu, np. ~/bin.")
    sys.exit(EXIT_MISSING_DEPENDENCY)


def run(cmd, cwd=None, check=False, capture=False):
    if capture:
        return subprocess.run(
            cmd, cwd=cwd, check=check,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True
        )
    print("$ " + " ".join(cmd))
    return subprocess.run(cmd, cwd=cwd, check=check)


def tool_version(tool):
    try:
        if tool == "ssh":
            cmd = [tool, "-V"]
        elif tool == "unison":
            cmd = [tool, "-version"]
        else:
            cmd = [tool, "--version"]
        p = run(cmd, capture=True)
        first = (p.stdout or "").splitlines()
        return first[0] if first else "installed"
    except Exception:
        return "installed"


def doctor(exit_on_missing=True, args=None):
    ensure_dirs()
    args = args or argparse.Namespace()
    missing = []
    checks = {
        "program": PROGRAM_NAME,
        "version": VERSION,
        "config": str(STATE_FILE),
        "logs": str(LOG_DIR),
        "run": str(RUN_DIR),
        "language": CURRENT_LANGUAGE,
        "tools": {},
        "remote": None,
        "ok": True,
    }

    for tool in REQUIRED_TOOLS:
        path = shutil.which(tool)
        if not path:
            missing.append(tool)
            checks["tools"][tool] = {"ok": False, "path": None, "version": None, "required": True}
        else:
            checks["tools"][tool] = {"ok": True, "path": path, "version": tool_version(tool), "required": True}

    for tool in OPTIONAL_TOOLS:
        path = shutil.which(tool)
        checks["tools"][tool] = {
            "ok": bool(path),
            "path": path,
            "version": tool_version(tool) if path else None,
            "required": False,
            "fallback": "rsync" if not path else None,
        }

    host = getattr(args, "host", None)
    remote_path = getattr(args, "remote_path", None)
    if host:
        checks["remote"] = check_remote(host, remote_path=remote_path)
        if not checks["remote"].get("ssh_ok"):
            checks["ok"] = False

    if missing:
        checks["ok"] = False

    if getattr(args, "json", False):
        print_json(checks)
    else:
        print(f"{PROGRAM_NAME} doctor")
        print(f"Version: {VERSION}")
        print(f"Config:  {STATE_FILE}")
        print(f"Logs:    {LOG_DIR}")
        print(f"Run:     {RUN_DIR}")
        print(f"Lock:    {LOCK_FILE}")
        print(f"Language: {CURRENT_LANGUAGE}")
        print()

        for tool, info in checks["tools"].items():
            required = "required" if info["required"] else "optional"
            if not info["ok"]:
                marker = "✗" if info["required"] else "⚠"
                print(f"{marker} {tool}: {t('status.missing')} ({required})")
                if tool == "unison":
                    print(f"  {t('doctor.unison_fallback')}")
            else:
                print(f"✓ {tool}: {info['path']} ({required})")
                print(f"  {info['version']}")

        if checks["remote"]:
            remote = checks["remote"]
            print()
            print(f"Remote: {host}")
            print(f"  ssh: {'ok' if remote.get('ssh_ok') else 'failed'}")
            if remote_path:
                print(f"  path {remote_path}: {'ok' if remote.get('path_ok') else 'missing/unavailable'}")
            print(f"  remote unison: {'ok' if remote.get('unison_ok') else 'missing'}")
            if not remote.get("unison_ok"):
                print("  unison fallback: rsync")

        if missing:
            print(f"\n{t('doctor.missing_tools')}")
            for tool in missing:
                print(f"  - {tool}")
            print(f"\n{t('doctor.install_macos')}")
            print("  brew install fswatch rsync git")
            print("  brew install unison   # optional, for mode=unison")

    if missing and exit_on_missing:
        sys.exit(EXIT_MISSING_DEPENDENCY)

    return not missing and checks["ok"]


def check_remote(host, remote_path=None):
    script_parts = ["echo JKS_SSH_OK"]
    if remote_path:
        quoted = remote_path.replace("'", "'\\''")
        script_parts.append(f"test -d '{quoted}' && echo JKS_PATH_OK || echo JKS_PATH_MISSING")
    script_parts.append("command -v unison >/dev/null 2>&1 && echo JKS_UNISON_OK || echo JKS_UNISON_MISSING")
    script = "; ".join(script_parts)
    result = subprocess.run(
        ["ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", host, script],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
    )
    output = result.stdout or ""
    return {
        "host": host,
        "remote_path": remote_path,
        "ssh_ok": result.returncode == 0 and "JKS_SSH_OK" in output,
        "path_ok": None if not remote_path else "JKS_PATH_OK" in output,
        "unison_ok": "JKS_UNISON_OK" in output,
        "returncode": result.returncode,
        "output": output.strip().splitlines()[-10:],
    }


def ensure_git(path):
    git_dir = Path(path) / ".git"
    if not git_dir.exists():
        run(["git", "init"], cwd=path, check=True)

    gitignore = Path(path) / ".gitignore"
    required_entries = [".DS_Store", "worktree/.git/", ".usp-cache/"]

    if gitignore.exists():
        existing_lines = gitignore.read_text(encoding="utf-8").splitlines()
    else:
        existing_lines = []

    changed = False
    for entry in required_entries:
        if entry not in existing_lines:
            existing_lines.append(entry)
            changed = True

    if changed or not gitignore.exists():
        content = "\n".join(existing_lines).rstrip() + "\n\n"
        gitignore.write_text(content, encoding="utf-8")


def ensure_git_with_tracking(path):
    git_existed = (Path(path) / ".git").exists()
    gitignore_existed = (Path(path) / ".gitignore").exists()
    ensure_git(path)
    created_git = not git_existed and (Path(path) / ".git").exists()
    created_gitignore = not gitignore_existed and (Path(path) / ".gitignore").exists()
    return created_git, created_gitignore


def cleanup_aborted_init(path, created_git=False, created_gitignore=False):
    print("\nPrzerwano konfigurację. Sprzątam niedokończony init.")
    state = load_state()

    if path in state.get("projects", {}):
        print("Projekt jest już zapisany w state.json, nie usuwam plików projektu.")
        return

    git_dir = Path(path) / ".git"
    gitignore = Path(path) / ".gitignore"

    if created_git and git_dir.exists():
        shutil.rmtree(git_dir)
        print("Usunięto tymczasowe .git")

    if created_gitignore and gitignore.exists():
        gitignore.unlink()
        print("Usunięto tymczasowe .gitignore")

    print("Zakończono bez zapisu projektu.")


def git_commit_env():
    env = os.environ.copy()
    env.setdefault("GIT_AUTHOR_NAME", "JKSync")
    env.setdefault("GIT_AUTHOR_EMAIL", "jksync@localhost")
    env.setdefault("GIT_COMMITTER_NAME", env["GIT_AUTHOR_NAME"])
    env.setdefault("GIT_COMMITTER_EMAIL", env["GIT_AUTHOR_EMAIL"])
    return env


def git_commit(path, message):
    run(["git", "add", "-A"], cwd=path)
    diff = subprocess.run(["git", "diff", "--cached", "--quiet"], cwd=path)
    if diff.returncode == 0:
        print("Git: brak zmian do commita.")
        return False
    print("$ git commit -m " + json.dumps(message))
    result = subprocess.run(["git", "commit", "-m", message], cwd=path, env=git_commit_env())
    return result.returncode == 0


def prompt_bool(question, default=True):
    suffix = "[T/n]" if default else "[t/N]"
    value = input(f"{question} {suffix}: ").strip().lower()
    if not value:
        return default
    return value in ["t", "tak", "y", "yes"]


def prompt_int(question, default):
    value = input(f"{question} [{default}]: ").strip()
    if not value:
        return default
    return int(value)


def prompt_float(question, default):
    value = input(f"{question} [{default}]: ").strip()
    if not value:
        return default
    return float(value)


